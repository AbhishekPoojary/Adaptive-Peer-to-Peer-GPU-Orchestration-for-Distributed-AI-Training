# =============================================================
# Dockerfile.agent – GPU Agent Node
# =============================================================
# For GPU-enabled hosts, change base image to:
#   FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04
# and replace python3.11-slim with the NVIDIA base.
# =============================================================
FROM python:3.11-slim

LABEL description="Adaptive P2P GPU Orchestration – Agent Node"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy only what the agent needs
COPY gpu_agent/  gpu_agent/
COPY training/   training/
COPY utils/      utils/
COPY config.yaml .

RUN useradd --no-create-home --shell /bin/false appuser && \
    mkdir -p logs checkpoints data && \
    chown -R appuser:appuser /app

USER appuser

# AGENT_PORT is set per-container in docker-compose.yml
EXPOSE ${AGENT_PORT:-8001}

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request, os; urllib.request.urlopen(f'http://localhost:{os.getenv(\"AGENT_PORT\",\"8001\")}/health')" || exit 1

CMD ["sh", "-c", \
     "uvicorn gpu_agent.agent:app --host 0.0.0.0 --port ${AGENT_PORT:-8001}"]
