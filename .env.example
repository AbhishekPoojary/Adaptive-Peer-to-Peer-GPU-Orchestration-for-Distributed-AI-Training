# =============================================================
# .env.example
# GPU Orchestration – Environment Variable Reference
# =============================================================
# Copy this file to .env and fill in your values.
# All values can also be passed as plain environment variables.
# =============================================================

# ─── SECURITY ────────────────────────────────────────────────
# Required: shared secret between orchestrator and all agents.
# Change this before deploying. Minimum 16 characters recommended.
ORCHESTRATOR_API_KEY=changeme-set-a-strong-key-here

# Comma-separated list of allowed CORS origins.
# Use * to allow all (development only).
ALLOWED_ORIGINS=*

# ─── DATABASE ────────────────────────────────────────────────
# SQLite (default, zero config):
DATABASE_URL=sqlite:///./gpu_orchestration.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://gpu_user:strongpass@localhost:5432/gpu_orch
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ─── ORCHESTRATOR ────────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
SCHEDULER_TYPE=adaptive         # round_robin | least_loaded | adaptive
HEARTBEAT_TIMEOUT_S=15
HEARTBEAT_SWEEP_S=5

# Adaptive scheduler weights (lower score = better node)
# Score_i = alpha * Load_i - beta * Reliability_i + gamma * Latency_i
ADAPTIVE_ALPHA=0.5
ADAPTIVE_BETA=0.4
ADAPTIVE_GAMMA=0.1

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text         # text (dev) | json (production)

# ─── AGENT (set per agent node) ──────────────────────────────
# Unique identifier for this agent node.
NODE_ID=node-1

# The IP/hostname of this machine that the ORCHESTRATOR can reach back to.
# Leave blank for auto-detection (uses socket to find local IP).
AGENT_HOST=

# Port this agent service listens on.
AGENT_PORT=8001

# Full URL of the orchestrator (including port, no trailing slash).
ORCHESTRATOR_URL=http://YOUR-ORCHESTRATOR-IP:8000

# Seconds between heartbeat pings.
HEARTBEAT_INTERVAL_S=5

# ─── TRAINING ────────────────────────────────────────────────
CHECKPOINT_DIR=./checkpoints
DATA_DIR=./data
